# ChartNav API — runtime configuration contract.
# See docs/build/12-runtime-config.md for the full reference.

# ---- Environment name (informational) ----
# dev | test | ci | prod
CHARTNAV_ENV=dev

# ---- Database ----
# Required. SQLAlchemy URL.
# Local dev default (SQLite file in apps/api/chartnav.db):
DATABASE_URL=sqlite:///./chartnav.db
# Postgres example:
# DATABASE_URL=postgresql+psycopg://chartnav:chartnav@localhost:5432/chartnav

# ---- Auth transport ----
# header  → dev only. Reads X-User-Email (trivially spoofable).
# bearer  → production-shaped placeholder. JWT validation is NOT yet
#           implemented; requests return 501 auth_bearer_not_implemented.
#           Setting this mode REQUIRES the three JWT vars below or the
#           app refuses to import.
CHARTNAV_AUTH_MODE=header

# Required when CHARTNAV_AUTH_MODE=bearer:
# CHARTNAV_JWT_ISSUER=https://auth.example.com/
# CHARTNAV_JWT_AUDIENCE=chartnav-api
# CHARTNAV_JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json

# ---- Entrypoint ----
# If 1, the container entrypoint will run scripts_seed.py after migrations.
# Keep 0 in production; seed is for dev/demo.
CHARTNAV_RUN_SEED=0

# ---- Uvicorn ----
API_HOST=0.0.0.0
API_PORT=8000
