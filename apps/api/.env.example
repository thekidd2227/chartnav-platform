# ChartNav API — runtime configuration contract.
# Full reference: docs/build/12-runtime-config.md

# ---- Environment name (informational) ----
# dev | test | ci | prod
CHARTNAV_ENV=dev

# ---- Database ----
# Required. SQLAlchemy URL.
DATABASE_URL=sqlite:///./chartnav.db
# Postgres example:
# DATABASE_URL=postgresql+psycopg://chartnav:chartnav@localhost:5432/chartnav

# ---- Auth transport ----
# header  → dev only. Reads X-User-Email (trivially spoofable).
# bearer  → production. Validates `Authorization: Bearer <jwt>`
#           against CHARTNAV_JWT_JWKS_URL (signature + iss + aud + exp).
#           Mapping from token to users row is by claim
#           CHARTNAV_JWT_USER_CLAIM (default "email").
CHARTNAV_AUTH_MODE=header

# Required when CHARTNAV_AUTH_MODE=bearer (app refuses to import otherwise):
# CHARTNAV_JWT_ISSUER=https://auth.example.com/
# CHARTNAV_JWT_AUDIENCE=chartnav-api
# CHARTNAV_JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# CHARTNAV_JWT_USER_CLAIM=email

# ---- CORS ----
# Comma-separated origins. Empty string → same-origin only.
# The default covers local Vite dev on both :5173 (developer) and :5174 (E2E).
CHARTNAV_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# ---- Rate limiting (per process, in-memory) ----
# Requests per 60s window per (client_ip, path). 0 disables.
CHARTNAV_RATE_LIMIT_PER_MINUTE=120

# ---- Entrypoint ----
# If 1, container entrypoint runs scripts_seed.py after migrations.
# Keep 0 in production.
CHARTNAV_RUN_SEED=0

# ---- Uvicorn ----
API_HOST=0.0.0.0
API_PORT=8000
