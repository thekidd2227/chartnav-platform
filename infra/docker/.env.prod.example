# ChartNav — production env contract (docker-compose.prod.yml).
#
# Copy to `.env.prod` next to this file, fill the REQUIRED fields,
# then: `cd infra/docker && docker compose --env-file .env.prod -f docker-compose.prod.yml up -d`.
#
# REQUIRED vs OPTIONAL marked per line. Preflight
# (`scripts/deploy_preflight.sh`) will refuse to proceed if any
# REQUIRED field is missing or insecure.
#
# NEVER commit `.env.prod` with real secrets. Use your org's
# secret store (AWS SSM / HashiCorp Vault / etc.) to populate it at
# deploy time.

# ----------------------------- Image pin -----------------------------
# REQUIRED. Image owner + tag. Rollback = change TAG + restart.
CHARTNAV_IMAGE_OWNER=thekidd2227
CHARTNAV_IMAGE_TAG=v0.1.0

# ---------------------------- Runtime ------------------------------
# REQUIRED. Must be "production" so the in-process validator fails
# fast on missing required fields.
CHARTNAV_ENV=production

# ---------------------------- Postgres -----------------------------
# REQUIRED. The compose stack runs its own Postgres; these are
# the credentials for that instance. Storage is the Docker-managed
# volume `chartnav_pgdata`.
POSTGRES_DB=chartnav
POSTGRES_USER=chartnav
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# ----------------------------- Auth --------------------------------
# REQUIRED in production: bearer (JWT) mode only. 'header' mode is
# dev-only and deploy_preflight will refuse it.
CHARTNAV_AUTH_MODE=bearer
# REQUIRED when AUTH_MODE=bearer.
CHARTNAV_JWT_ISSUER=https://auth.example.com/
CHARTNAV_JWT_AUDIENCE=chartnav-api
CHARTNAV_JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# Optional; default "email" if omitted.
CHARTNAV_JWT_USER_CLAIM=email

# ----------------------------- CORS --------------------------------
# REQUIRED. Must NOT include localhost/127.0.0.1 in production;
# preflight rejects those origins. Comma-separated list of exact
# origins the frontend ships from.
CHARTNAV_CORS_ALLOW_ORIGINS=https://chart.example.com

# ------------------------- Rate limiting ---------------------------
# Requests per minute per (remote_addr, path). 0 disables.
# 120 is a reasonable default for a clinical UI.
CHARTNAV_RATE_LIMIT_PER_MINUTE=120

# ---------------------- Audit retention ----------------------------
# Days. 0 = retain forever. Operator runs
# `python scripts/audit_retention.py` on their cadence.
CHARTNAV_AUDIT_RETENTION_DAYS=730

# ------------------- Evidence signing (optional) -------------------
# If your org requires HMAC-signed evidence bundles, set either:
#
#   (a) a single legacy key (auto-aliased as key_id 'default'):
#       CHARTNAV_EVIDENCE_SIGNING_HMAC_KEY=...
#
#   (b) the keyring (preferred — supports rotation):
#       CHARTNAV_EVIDENCE_SIGNING_HMAC_KEYS={"k1":"...","k2":"..."}
#
# When unset, bundles are unsigned (still hash-anchored).
# See docs/build/60-evidence-operations-trust-retention-closure.md.

# CHARTNAV_EVIDENCE_SIGNING_HMAC_KEY=
# CHARTNAV_EVIDENCE_SIGNING_HMAC_KEYS={"k1":"replace-with-real-secret"}

# ------------------- Platform mode --------------------------------
# standalone | integrated_readthrough | integrated_writethrough
CHARTNAV_PLATFORM_MODE=standalone

# ------------------- Integration adapter --------------------------
# stub (dev) | fhir (real FHIR read-through)
CHARTNAV_INTEGRATION_ADAPTER=stub
# Required when adapter=fhir:
# CHARTNAV_FHIR_BASE_URL=https://fhir.example.com/
# CHARTNAV_FHIR_AUTH_TYPE=bearer
# CHARTNAV_FHIR_BEARER_TOKEN=

# ------------------- Audio intake ---------------------------------
CHARTNAV_AUDIO_UPLOAD_DIR=/var/lib/chartnav/audio
CHARTNAV_AUDIO_UPLOAD_MAX_BYTES=26214400
CHARTNAV_AUDIO_INGEST_MODE=async
CHARTNAV_STT_PROVIDER=stub

# ------------------- Seed on boot ---------------------------------
# Must be 0 in production. Setting to 1 re-runs the idempotent seed
# against your production DB on every container start. Only set to
# 1 on first-install, then flip back to 0.
CHARTNAV_RUN_SEED=0
