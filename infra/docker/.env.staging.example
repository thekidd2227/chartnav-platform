# ChartNav — STAGING env contract.
#
# Copy to `infra/docker/.env.staging` and fill in real values.
# The compose file uses `${VAR:?msg}` so any required value missing
# here blocks startup with an explicit error. No silent defaults.
#
# Full reference: docs/build/12-runtime-config.md
# Staging procedures: docs/build/19-staging-deployment.md

# ---- Image pinning (rollback lives here) --------------------------------
# The exact image tag to run. Bump + re-up to deploy; re-pin to the prior
# tag + re-up to roll back.
CHARTNAV_IMAGE_OWNER=thekidd2227
CHARTNAV_IMAGE_TAG=v0.1.0

# ---- Database -----------------------------------------------------------
POSTGRES_DB=chartnav
POSTGRES_USER=chartnav
POSTGRES_PASSWORD=change-me-in-real-staging
POSTGRES_PORT=5432
# Optional override; otherwise the compose file constructs this from the
# three POSTGRES_* vars above.
# DATABASE_URL=postgresql+psycopg://chartnav:change-me@db:5432/chartnav

# ---- Auth ---------------------------------------------------------------
# In staging, bearer mode is the intended setting. header is only
# acceptable for very early QA with a seeded user set; switch before any
# external traffic.
CHARTNAV_AUTH_MODE=bearer
CHARTNAV_JWT_ISSUER=https://auth.staging.example.com/
CHARTNAV_JWT_AUDIENCE=chartnav-api
CHARTNAV_JWT_JWKS_URL=https://auth.staging.example.com/.well-known/jwks.json
CHARTNAV_JWT_USER_CLAIM=email

# ---- CORS ---------------------------------------------------------------
# Staging web origin(s). NEVER put `*` here.
CHARTNAV_CORS_ALLOW_ORIGINS=https://app.staging.example.com

# ---- Rate limiting ------------------------------------------------------
# Per-process sliding window. Bump for load-testing windows.
CHARTNAV_RATE_LIMIT_PER_MINUTE=120

# ---- Seed ---------------------------------------------------------------
# 1 = run scripts_seed.py after migrations (demo fixtures; QA convenience).
# 0 = never seed (the default once there's real staging data).
CHARTNAV_RUN_SEED=0

# ---- API -----------------------------------------------------------------
API_PORT=8000
